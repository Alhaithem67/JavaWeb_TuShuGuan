<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
    namespace:名称空间
-->
<mapper namespace="org.example.javawebtushuguan.mapper.BookMapper">
<!--    查询所有图书-->
    <select id="selectAll" resultType="org.example.javawebtushuguan.entity.Book">
        select * from book;
    </select>

<!--    查询指定图书-->
    <select id="selectById" resultType="org.example.javawebtushuguan.entity.Book">
        select * from book where book_id=#{id};
    </select>

    <!--    借阅图书-->
    <update id="borrowBook">
        update book set book_state='已借出' where book_id=#{id}
    </update>

    <!--    归还图书-->
    <update id="returnBook">
        update book set book_state='未借出' where book_id=#{id}
    </update>
    <!--    *参数占位符
            1.#{}:会将其替换为?，为了防止sql注入
            2.${}:拼sql，会存在sql注入问题
            3.使用时机:
                *参数传递时:#{}
                *表名或列名不固定的情况下:${} 但是会存在sql注入的问题


            *参数类型: parameterType 可省略
            *特殊字符的处理:
                1.转义字符:小于号
                2.CDATA区:
    -->
<!--    <select id="selectById" parameterType="int" resultType="com.Alhaitham.pojo.User">-->
<!--        select * from stu where id = #{id};-->
<!--    </select>-->
</mapper>